# ── DATABASE (Neon Postgres) ──────────────────────────
DATABASE_URL=postgresql://user:password@your-project-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── DATABASE (legacy MySQL — only needed to re-run backend/migration/migrate-to-neon.js) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=relateme

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── SERVER ────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────
# In production set this to your actual frontend URL
FRONTEND_URL=http://localhost:3000
